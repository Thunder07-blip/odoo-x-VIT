{
  "info": {
    "name": "ExpenseFlow API",
    "_postman_id": "expenseflow-collection",
    "description": "All APIs for ExpenseFlow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Signup",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"companyName\": \"TestCorp\",\n  \"country\": \"India\",\n  \"currency\": \"INR\",\n  \"name\": \"Admin User\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/signup"
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Employee 1\",\n  \"email\": \"emp1@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"EMPLOYEE\"\n}"
        },
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Create Expense",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 100,\n  \"currency\": \"USD\",\n  \"category\": \"Food\",\n  \"description\": \"Lunch\",\n  \"date\": \"2026-03-29\"\n}"
        },
        "url": "{{baseUrl}}/api/expenses"
      }
    },
    {
      "name": "Get Expenses",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/expenses"
      }
    },
    {
      "name": "Approve Expense",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"expenseId\": \"REPLACE_ID\",\n  \"action\": \"APPROVE\"\n}"
        },
        "url": "{{baseUrl}}/api/approvals/action"
      }
    },
    {
      "name": "OCR Test",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"imageBase64\": \"PASTE_BASE64_IMAGE\"\n}"
        },
        "url": "{{baseUrl}}/api/ocr"
      }
    }
  ]
}
generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Company {
  id           String   @id @default(uuid())
  name         String
  country      String
  currencyCode String
  createdAt    DateTime @default(now())

  users         User[]
  expenses      Expense[]
  approvalRules ApprovalRule[]
}

model User {
  id           String  @id @default(uuid())
  companyId    String
  name         String
  email        String  @unique
  passwordHash String
  role         Role
  managerId    String?

  createdAt DateTime @default(now())

  company      Company @relation(fields: [companyId], references: [id])
  manager      User?   @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates User[]  @relation("ManagerRelation")

  expenses      Expense[]
  approvals     ExpenseApproval[]
  approvalSteps ApprovalStep[]
  rules         ApprovalRule[]
}

model Expense {
  id         String @id @default(uuid())
  companyId  String
  employeeId String

  amountOriginal   Float
  currencyOriginal String
  amountConverted  Float

  category    String
  description String
  remarks     String?
  date        DateTime

  receiptUrl String?

  status    ExpenseStatus @default(DRAFT)
  createdAt DateTime      @default(now())

  company  Company @relation(fields: [companyId], references: [id])
  employee User    @relation(fields: [employeeId], references: [id])

  approvals ExpenseApproval[]
  ocrData   OCRData?
}

model ApprovalRule {
  id        String @id @default(uuid())
  companyId String
  userId    String

  ruleName    String
  description String?

  isManagerApprover     Boolean @default(false)
  isSequential          Boolean @default(false)
  minApprovalPercentage Int     @default(100)

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  steps ApprovalStep[]
}

model ApprovalStep {
  id     String @id @default(uuid())
  ruleId String

  approverId String
  stepOrder  Int
  isRequired Boolean @default(false)

  rule     ApprovalRule @relation(fields: [ruleId], references: [id])
  approver User         @relation(fields: [approverId], references: [id])
}

model ExpenseApproval {
  id         String @id @default(uuid())
  expenseId  String
  approverId String

  stepOrder Int

  status  ApprovalStatus @default(PENDING)
  comment String?

  actedAt DateTime?

  expense  Expense @relation(fields: [expenseId], references: [id])
  approver User    @relation(fields: [approverId], references: [id])
}

model OCRData {
  id        String @id @default(uuid())
  expenseId String @unique

  rawText       String?
  extractedJson Json
  confidence    Float?

  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
